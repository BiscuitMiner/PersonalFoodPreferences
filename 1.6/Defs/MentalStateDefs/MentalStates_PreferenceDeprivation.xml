    <category>Misc</category>
    <colonistsOnly>true</colonistsOnly>
    <minTicksBeforeRecovery>60000</minTicksBeforeRecovery>
    <maxTicksBeforeRecovery>120000</maxTicksBeforeRecovery>
    <recoveryMtbDays>0.166</recoveryMtbDays>
    <recoverFromSleep>true</recoverFromSleep>
    <moodRecoveryThought>Catharsis</moodRecoveryThought>
    <blockNormalThoughts>true</blockNormalThoughts>
    <nameColor>(0.65, 0.9, 0.93)</nameColor>
    <recoveryMessage>{0} is no longer wandering over preference deprivation.</recoveryMessage>
    <beginLetterLabel>preference deprivation</beginLetterLabel>
    <beginLetter>{0} has gone too long without eating preferred food and is wandering outside in frustration.</beginLetter>
    <beginLetterDef>NegativeEvent</beginLetterDef>
    <baseInspectLine>Mental state: Wandering over preference deprivation</baseInspectLine>
    <allowBeatfire>true</allowBeatfire>
    <escapingPrisonersIgnore>true</escapingPrisonersIgnore>
  </MentalStateDef>
</Defs>
