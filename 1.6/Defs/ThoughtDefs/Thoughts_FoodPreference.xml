<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThoughtDef>
    <defName>AtePreferredFood</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>0.5</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>ate preferred food</label>
        <description>Ate a favorite type of food.</description>
        <baseMoodEffect>5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>PFP_PreferenceSatisfied</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>14</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>finally ate what I wanted</label>
        <description>Finally! That's exactly what I wanted to eat.</description>
        <baseMoodEffect>20</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>AteNonPreferredFood</defName>
    <thoughtClass>Thought_Memory</thoughtClass>
    <durationDays>0.5</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>ate non-preferred food</label>
        <description>Ate a disliked type of food.</description>
        <baseMoodEffect>-5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>PFP_NoRecentPreferredFood</defName>
    <thoughtClass>Thought_Situational</thoughtClass>
    <workerClass>PersonalFoodPreferences.ThoughtWorker_PreferenceDeprivation_NoRecentPreferred</workerClass>
    <doNotApplyToQuestLodgers>true</doNotApplyToQuestLodgers>
    <stages>
      <li>
        <label>taste fatigue</label>
        <description>Every day it's the same thing... I can't even remember the last time I ate food I liked.</description>
        <baseMoodEffect>-3</baseMoodEffect>
      </li>
      <li>
        <label>dietary aversion</label>
        <description>This again! Can't we grow something else?</description>
        <baseMoodEffect>-8</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

</Defs>
