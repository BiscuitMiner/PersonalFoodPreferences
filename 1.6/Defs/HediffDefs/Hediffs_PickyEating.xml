<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>PFP_MildPickyEating</defName>
    <label>picky eating (mild)</label>
    <description>This pawn has eaten the same food category for too long, causing a mild nutritional imbalance.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <scenarioCanAdd>true</scenarioCanAdd>
    <initialSeverity>0.5</initialSeverity>
    <maxSeverity>0.5</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Discoverable" />
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-0.05</MoveSpeed>
          <GeneralLaborSpeed>-0.05</GeneralLaborSpeed>
          <ImmunityGainSpeed>-0.10</ImmunityGainSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>PFP_SeverePickyEating</defName>
    <label>picky eating (severe)</label>
    <description>This pawn's monotonous diet has developed into severe picky eating, causing a significant nutritional imbalance.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <scenarioCanAdd>true</scenarioCanAdd>
    <initialSeverity>0.75</initialSeverity>
    <maxSeverity>0.75</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Discoverable" />
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.10</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.10</offset>
          </li>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>-0.20</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-0.10</MoveSpeed>
          <GeneralLaborSpeed>-0.10</GeneralLaborSpeed>
          <ImmunityGainSpeed>-0.20</ImmunityGainSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>PFP_PermanentPickyEating</defName>
    <label>picky eating (permanent)</label>
    <description>This pawn's long-term monotonous diet has caused lasting damage to their physical condition.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <scenarioCanAdd>true</scenarioCanAdd>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Discoverable" />
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>-0.30</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-0.15</MoveSpeed>
          <GeneralLaborSpeed>-0.15</GeneralLaborSpeed>
          <ImmunityGainSpeed>-0.30</ImmunityGainSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
</Defs>
