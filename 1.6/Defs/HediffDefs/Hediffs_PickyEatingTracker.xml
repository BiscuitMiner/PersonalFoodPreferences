<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>PFP_PickyEating</defName>
    <label>picky eating</label>
    <labelNoun>picky eating</labelNoun>
    <description>This pawn's monotonous diet has led to picky eating, causing nutritional imbalance that worsens over time.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>true</scenarioCanAdd>
    <everCurableByItem>true</everCurableByItem>
    <initialSeverity>0.0001</initialSeverity>
    <comps>
      <li Class="PersonalFoodPreferences.HediffCompProperties_PickyEating" />
      <li Class="HediffCompProperties_Discoverable" />
    </comps>
    <stages>
      <!-- Stage 0: inactive (minSeverity 0) — no effects -->
      <li>
        <label>inactive</label>
        <minSeverity>0</minSeverity>
      </li>
      <!-- Stage 1: Mild (severity >= 0.25) -->
      <li>
        <label>mild</label>
        <minSeverity>0.1</minSeverity>
        <capMods>
          <li><capacity>Moving</capacity><offset>-0.05</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.05</offset></li>
          <li><capacity>BloodFiltration</capacity><offset>-0.10</offset></li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-0.05</MoveSpeed>
          <GeneralLaborSpeed>-0.05</GeneralLaborSpeed>
          <ImmunityGainSpeed>-0.10</ImmunityGainSpeed>
        </statOffsets>
      </li>
      <!-- Stage 2: Severe (severity >= 0.6) -->
      <li>
        <label>severe</label>
        <minSeverity>0.5</minSeverity>
        <capMods>
          <li><capacity>Moving</capacity><offset>-0.10</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.10</offset></li>
          <li><capacity>BloodFiltration</capacity><offset>-0.20</offset></li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-0.10</MoveSpeed>
          <GeneralLaborSpeed>-0.10</GeneralLaborSpeed>
          <ImmunityGainSpeed>-0.20</ImmunityGainSpeed>
        </statOffsets>
      </li>
      <!-- Stage 3: Permanent (severity >= 0.95) -->
      <li>
        <label>permanent</label>
        <minSeverity>0.9</minSeverity>
        <capMods>
          <li><capacity>Moving</capacity><offset>-0.15</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.15</offset></li>
          <li><capacity>BloodFiltration</capacity><offset>-0.30</offset></li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-0.15</MoveSpeed>
          <GeneralLaborSpeed>-0.15</GeneralLaborSpeed>
          <ImmunityGainSpeed>-0.30</ImmunityGainSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
</Defs>
